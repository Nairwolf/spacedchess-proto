# Copy to .env and adjust. All values have working defaults for local use.

# Password for the bundled PostgreSQL container.
POSTGRES_PASSWORD=spacedchess

# Host port the app is exposed on.
PORT=8080

# Set to "true" when the app is served over HTTPS.
SECURE_COOKIES=false

# Set to "false" to disable self-registration once your account exists.
ALLOW_REGISTRATION=true
